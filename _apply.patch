+_moe_sorting_buf_cache: dict = {}
+
+
+def _get_moe_sorting_bufs(
+    M, topk, num_experts, block_size, model_dim, moebuf_dtype, device
+):
+    key = (device.index, M, topk, num_experts, block_size, model_dim, moebuf_dtype)
+    if key not in _moe_sorting_buf_cache:
+        max_num_tokens_padded = int(M * topk + num_experts * block_size - topk)
+        sorted_ids = torch.empty(
+            max_num_tokens_padded, dtype=torch.int32, device=device
+        )
+        sorted_weights = torch.empty(
+            max_num_tokens_padded, dtype=torch.float32, device=device
+        )
+        sorted_expert_ids = torch.empty(
+            max_num_tokens_padded // block_size, dtype=torch.int32, device=device
+        )
+        num_valid_ids = torch.empty(1, dtype=torch.int32, device=device)
+        moe_buf = torch.empty(
+            (max_num_tokens_padded, model_dim), dtype=moebuf_dtype, device=device
+        )
+        _moe_sorting_buf_cache[key] = (
+            sorted_ids,
+            sorted_weights,
+            sorted_expert_ids,
+            num_valid_ids,
+            moe_buf,
+        )
+    return _moe_sorting_buf_cache[key]
+
