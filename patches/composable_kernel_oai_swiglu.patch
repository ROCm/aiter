@@ -278,17 +278,42 @@ struct GridwiseMoeGemm : public GridwiseGemm_xdl_cshuffle_base<
     using Base::NumDTensor;
     static constexpr auto BlockSizeNumber = Number<BlockSize>{};
 
-    // Clamp limit for swiglustep_and_mul: silu(g).clamp(max=L) * u.clamp(+-L), L hardcoded to 7.0
+    // OAI SwiGLU parameters used by MiniMax-M3.
     static constexpr float kSwiGluClamp = 7.0f;
+    static constexpr float kSwiGluAlpha = 1.702f;
+    static constexpr float kSwiGluBeta  = 1.0f;
 
-    // Helper: apply SwiGLU-step activation (silu + symmetric clamp) and return gate*up.
+    __host__ __device__ static float round_to_bf16_float(float x)
+    {
+        return type_convert<float>(type_convert<bhalf_t>(x));
+    }
+
+    template <typename OutDataType>
+    __host__ __device__ static float round_to_output_float(float x)
+    {
+        if constexpr(is_same_v<remove_cvref_t<OutDataType>, bhalf_t>)
+        {
+            return round_to_bf16_float(x);
+        }
+        else
+        {
+            return x;
+        }
+    }
+
+    // Helper: apply OAI SwiGLU and return gate * sigmoid(alpha * gate) * (up + beta).
     // Used by all four swiglustep_and_mul epilogue paths (quant/non-quant x pipeline-A/B).
-    __host__ __device__ static constexpr float apply_swiglustep_activation(float gate, float up)
+    __host__ __device__ static float apply_swiglustep_activation(float gate, float up)
     {
-        tensor_operation::element_wise::Silu{}(gate, gate);
+        // MiniMax-M3's unfused shared MLP observes bf16 values between both
+        // FP8 GEMMs and the SwiGLU activation. Match that precision boundary
+        // before stage1 quantizes the activation for GEMM2.
+        gate = round_to_bf16_float(gate);
+        up   = round_to_bf16_float(up);
         gate = math::min(gate, kSwiGluClamp);
         up   = math::min(math::max(up, -kSwiGluClamp), kSwiGluClamp);
-        return gate * up;
+        const float sigmoid = 1.0f / (1.0f + math::exp(-kSwiGluAlpha * gate));
+        return round_to_bf16_float(gate * sigmoid * (up + kSwiGluBeta));
     }
 
     using mfma_selector = MfmaSelector<ComputeTypeA, MPerXdl, NPerXdl, ComputeTypeB>;
