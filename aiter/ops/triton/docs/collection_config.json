{
    "description": "Performance collection configuration for Triton 3.4 vs 3.6 comparison",
    "regression_threshold": {"pct": 0.5, "min_ns": 500},
    "num_runs": 3,
    "noise_method": "closest_pair_average",
    "m_values": [8, 16, 32, 64, 128, 256, 512, 8192],
    "configs": {
        "baseline": {
            "aiter_branch": "main",
            "triton_repo": "https://github.com/ROCm/triton.git",
            "triton_branch": "pytorch/rocm7.1_internal_testing",
            "triton_version": "3.4.0"
        },
        "main_latest": {
            "aiter_branch": "main",
            "triton_repo": "https://github.com/triton-lang/triton.git",
            "triton_branch": "main",
            "triton_version": "3.6.0"
        },
        "target": {
            "aiter_branch": "alizaidy/gfx950-kernel-fixes-cherry-picked",
            "triton_repo": "https://github.com/triton-lang/triton.git",
            "triton_branch": "main",
            "triton_version": "3.6.0"
        }
    },
    "kernels": [
        {
            "name": "a8w8",
            "bench_script": "bench_gemm_a8w8.py",
            "bench_flags": "",
            "kernel_filter": "_gemm_a8w8_kernel",
            "config_variant": "A8W8",
            "model_shapes_key": "gemm_a8w8"
        },
        {
            "name": "a8w8_blockscale",
            "bench_script": "bench_gemm_a8w8_blockscale.py",
            "bench_flags": "",
            "kernel_filter": "_gemm_a8w8_blockscale_kernel",
            "config_variant": "A8W8_BLOCKSCALE",
            "model_shapes_key": "gemm_a8w8_blockscale"
        },
        {
            "name": "a8w8_blockscale_preshuffle",
            "bench_script": "bench_gemm_a8w8_blockscale.py",
            "bench_flags": "-preshuffle",
            "kernel_filter": "_gemm_a8w8_blockscale_preshuffle_kernel",
            "config_variant": "A8W8_BLOCKSCALE_PRESHUFFLED",
            "model_shapes_key": null,
            "notes": "Requires -preshuffle flag patched into bench script on main"
        },
        {
            "name": "a8w8_per_token_scale",
            "bench_script": "bench_gemm_a8w8_per_token_scale.py",
            "bench_flags": "",
            "kernel_filter": "_gemm_a8w8_per_token_scale_kernel",
            "config_variant": "A8W8_PER_TOKEN_SCALE",
            "model_shapes_key": "gemm_a8w8_per_token_scale"
        },
        {
            "name": "a16w16",
            "bench_script": "bench_gemm_a16w16.py",
            "bench_flags": "",
            "kernel_filter": "_gemm_a16_w16_kernel",
            "config_variant": "A16W16",
            "model_shapes_key": "gemm_a16w16"
        },
        {
            "name": "a16w16_atomic",
            "bench_script": "bench_gemm_a16w16.py",
            "bench_flags": "--atomic",
            "kernel_filter": "_gemm_a16_w16_atomic_kernel",
            "config_variant": "A16W16-ATOMIC",
            "model_shapes_key": null
        },
        {
            "name": "a16w16_gated",
            "bench_script": "bench_gemm_a16w16_gating.py",
            "bench_flags": "",
            "kernel_filter": "_gemm_a16_w16_gated_kernel",
            "config_variant": "A16W16_GATED",
            "model_shapes_key": null
        },
        {
            "name": "a8wfp4",
            "bench_script": "bench_gemm_a8wfp4.py",
            "bench_flags": "",
            "kernel_filter": "_gemm_a8wfp4_kernel",
            "config_variant": "A8WFP4",
            "model_shapes_key": null,
            "notes": "Requires get_fp8_dtypes() patched into arch_info.py on main"
        },
        {
            "name": "afp4wfp4",
            "bench_script": "bench_gemm_afp4wfp4.py",
            "bench_flags": "",
            "kernel_filter": "_gemm_afp4wfp4_kernel",
            "config_variant": "AFP4WFP4",
            "model_shapes_key": "gemm_afp4wfp4"
        },
        {
            "name": "afp4wfp4_preshuffle",
            "bench_script": "bench_gemm_afp4wfp4.py",
            "bench_flags": "--shuffle",
            "kernel_filter": "_gemm_afp4wfp4_preshuffle_kernel",
            "config_variant": "AFP4WFP4_PRESHUFFLED",
            "model_shapes_key": "gemm_afp4wfp4"
        }
    ],
    "shape_discovery": {
        "method": "Shapes come from dedicated config files + model_shapes.json + fallback (8192,8192)",
        "config_dir": "aiter/ops/triton/configs/gemm",
        "model_shapes_file": "op_tests/op_benchmarks/triton/model_benchmarking_tool/model_shapes.json",
        "config_pattern": "gfx950-GEMM-{VARIANT}-N={N}-K={K}.json",
        "notes": "For each kernel, find all N,K pairs from config files matching the variant + model_shapes.json entries + always include (8192,8192). Cross with M_VALUES to get full shape list."
    },
    "collection_method": {
        "tool": "rocprof --stats (v1, NOT rocprofv3)",
        "command_template": "HIP_VISIBLE_DEVICES={GPU} rocprof --stats -o {PREFIX}.csv python {BENCH_DIR}/{SCRIPT} --shape {M} {N} {K} --metric time --layout TN {FLAGS}",
        "parse": "Read {PREFIX}.stats.csv, column 4 (AverageNs). Match main kernel by kernel_filter substring. Match reduce kernel by '_gemm_' AND 'reduce_kernel' in name. Total = main_ns + reduce_ns.",
        "bench_dir": "op_tests/op_benchmarks/triton"
    },
    "patches_needed_on_main": [
        {
            "file": "op_tests/op_benchmarks/triton/bench_gemm_a8w8_blockscale.py",
            "description": "Add -preshuffle flag and preshuffle kernel import for a8w8_blockscale_preshuffle collection",
            "details": "Import gemm_a8w8_blockscale_preshuffle, add shuffle param to bench_gemm_fn, add -preshuffle argparse arg, wire shuffle=args.preshuffle through"
        },
        {
            "file": "aiter/ops/triton/utils/_triton/arch_info.py",
            "description": "Add get_fp8_dtypes() function for a8wfp4 bench to work",
            "details": "def get_fp8_dtypes(): return (torch.float8_e5m2, torch.float8_e4m3fn) for gfx950/gfx1250, else (torch.float8_e5m2fnuz, torch.float8_e4m3fnuz)"
        }
    ],
    "existing_data": {
        "baseline_old": "/tmp/perf_comparison/baseline_consolidated.json",
        "target_old": "/tmp/perf_comparison/target_consolidated.json",
        "notes": "Old data from prior collection run. Baseline had 1104 shapes, target had 1176 shapes (feature branch has more NK pairs from new dedicated configs)."
    },
    "remaining_regressions": [
        {"kernel": "a16w16_gated", "m": 8192, "n": 8192, "k": 8192, "pct": 32.8, "status": "not_tuned"},
        {"kernel": "a8w8_blockscale", "m": 64, "n": 7168, "k": 16384, "pct": 6.5, "status": "compiler_regression"},
        {"kernel": "a16w16_atomic", "m": 256, "n": 256, "k": 7168, "pct": 5.9, "status": "improved_not_fixed"},
        {"kernel": "afp4wfp4", "m": 512, "n": 32768, "k": 512, "pct": 4.0, "status": "manually_improved"},
        {"kernel": "a8w8_blockscale", "m": 64, "n": 4096, "k": 7168, "pct": 3.6, "status": "compiler_regression"},
        {"kernel": "a8w8_blockscale", "m": 512, "n": 32768, "k": 512, "pct": 2.5, "status": "compiler_regression"},
        {"kernel": "afp4wfp4", "m": 32, "n": 18432, "k": 16384, "pct": 2.4, "status": "borderline"},
        {"kernel": "a8w8_per_token_scale", "m": 128, "n": 32768, "k": 5120, "pct": 1.7, "status": "borderline_noise"}
    ]
}
